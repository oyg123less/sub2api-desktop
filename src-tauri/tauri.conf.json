{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Amber",
  "version": "0.1.0",
  "identifier": "com.sub2api.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Amber 琥珀",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; frame-src https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/sub2api-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Personal use only. Includes components under LGPL v3 (sub2api).",
    "category": "DeveloperTool",
    "shortDescription": "Local OpenAI-compatible API gateway",
    "longDescription": "Amber turns your ChatGPT subscription into a local OpenAI-compatible API for personal use."
  },
  "plugins": {}
}
